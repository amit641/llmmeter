{
  "name": "llmmeter-sqlite",
  "version": "0.1.0",
  "description": "SQLite sink and query API for llmmeter.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "llmmeter-core": "workspace:*",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit641/llmmeter.git",
    "directory": "packages/sqlite"
  },
  "bugs": {
    "url": "https://github.com/amit641/llmmeter/issues"
  },
  "homepage": "https://github.com/amit641/llmmeter#readme",
  "author": "Amit Chowdhary"
}
